{
  "name": "pi-dag-cli",
  "version": "0.1.0",
  "description": "CLI que decompõe macro-tarefas em DAG e executa agentes IA em paralelo via Git Worktrees",
  "type": "module",
  "bin": {
    "pi-dag": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "preaa:benchmarks": "npm run build -- --pretty false",
    "aa:benchmarks": "node dist/scripts/list-aa-benchmarks.js",
    "test:aa:benchmarks": "npm run build -- --pretty false && node --test dist/scripts/list-aa-benchmarks.test.js"
  },
  "dependencies": {
    "@langchain/core": "^1.1.34",
    "@langchain/openai": "^1.3.0",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1"
  }
}
